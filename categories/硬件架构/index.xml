&lt;tr&gt;&lt;td&gt;Mul                         &lt;/td&gt;&lt;td&gt;     25&lt;/td&gt;&lt;td&gt;   0.972&lt;/td&gt;&lt;td&gt;  0.038880&lt;/td&gt;
