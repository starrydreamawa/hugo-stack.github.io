&lt;tr&gt;&lt;td&gt;Gather                      &lt;/td&gt;&lt;td&gt;      5&lt;/td&gt;&lt;td&gt;   0.027&lt;/td&gt;&lt;td&gt;  0.005400&lt;/td&gt;
&lt;tr&gt;&lt;td&gt;Slice                       &lt;/td&gt;&lt;td&gt;      2&lt;/td&gt;&lt;td&gt;   0.026&lt;/td&gt;&lt;td&gt;  0.013000&lt;/td&gt;
&lt;tr&gt;&lt;td&gt;Tanh                        &lt;/td&gt;&lt;td&gt;      1&lt;/td&gt;&lt;td&gt;   0.023&lt;/td&gt;&lt;td&gt;  0.023000&lt;/td&gt;
