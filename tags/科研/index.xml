&lt;tr&gt;&lt;td&gt;Squeeze                     &lt;/td&gt;&lt;td&gt;      1&lt;/td&gt;&lt;td&gt;   0.009&lt;/td&gt;&lt;td&gt;  0.009000&lt;/td&gt;
&lt;tr&gt;&lt;td&gt;Range                       &lt;/td&gt;&lt;td&gt;      1&lt;/td&gt;&lt;td&gt;   0.007&lt;/td&gt;&lt;td&gt;  0.007000&lt;/td&gt;
&lt;tr&gt;&lt;td&gt;Expand                      &lt;/td&gt;&lt;td&gt;      1&lt;/td&gt;&lt;td&gt;   0.006&lt;/td&gt;&lt;td&gt;  0.006000&lt;/td&gt;
